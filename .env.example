# Required: your private ntfy topic (like a password — pick something unguessable)
NTFY_TOPIC=my-secret-topic-name

# Optional: ntfy server URL (default: https://ntfy.sh)
# NTFY_SERVER=https://ntfy.sh

# Optional: comma-separated arXiv categories on SciRate (default: quant-ph)
# SCIRATE_CATEGORIES=quant-ph

# Optional: SciRate "range" query param — days to look back (default: 1)
# SCIRATE_RANGE_DAYS=1

# Optional: max papers in the notification (default: 5)
# TOP_N=5

# Optional: minimum scite count to include a paper (default: 1)
# MIN_SCITES=1

# Optional: ntfy priority — min, low, default, high, max (default: default)
# NTFY_PRIORITY=default
